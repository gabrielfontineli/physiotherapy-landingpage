# Copie para .env.local e preencha. Tudo é OPCIONAL — o site roda sem nada
# disso (reviews usam fallback, Sanity/GTM só não carregam).

# Google Places — reviews reais no carrossel de depoimentos.
# Requer no Google Cloud Console: projeto com BILLING ATIVO + "Places API" habilitada.
# Sem billing a API retorna REQUEST_DENIED e o site usa reviews de fallback.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Sanity CMS — conteúdo dinâmico (depoimentos, FAQ, config da guia) + /studio
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Google Tag Manager — fonte única de analytics (roteia GA4/Meta/TikTok no painel)
NEXT_PUBLIC_GTM_ID=

# Legado — pixels diretos, NÃO usados pelo código (GTM cobre). Só referência.
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
